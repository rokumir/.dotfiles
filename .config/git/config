[user]
    name       = Lopt
    email      = lopt.loptr@proton.me
    signingkey = ~/.ssh/id_ed25519.pub

[core]
    autocrlf     = input
    askpass      =           # disable credential manager
    compression  = 9
    whitespace   = error
    preloadindex = true
    pager        = delta

[include]
    path = ~/.config/delta/themes/catppuccin.gitconfig
    path = ~/.config/git/alias

[init]
    defaultBranch = dev

[gpg]
    format = ssh

[commit]
    template = ~/.config/git/template
    gpgsign  = true

[push]
    autoSetupRemote = true    # easier to push new branches
    default         = current # push only current branch by default
    followTags      = true    # push also tags

[pull]
    rebase = true

[submodule]
    fetchJobs = 16

[rebase]
    autoStash = true

[branch]
    autosetuprebase = always  # Avoid messy merge commits with autorebase
    sort            = -committerdate

[tag]
    sort = -taggerdate

[status]
    branch    = true
    showStash = true

[pager]
    branch = false
    tag    = false


# ---------------------------------------------------------------
# --- Diff & Merge Tools
[diff]
    tool             = nvimdiff
    context          = 3
    renames          = copies
    interHunkContext = 10

[difftool]
    prompt = false

[difftool "nvimdiff"]
    cmd = nvim -c DiffviewOpen

[merge]
    tool = diffview # nvimdiff

[mergetool "diffview"]
    prompt = true
    keepBackup = false
    layout = "LOCAL,BASE,REMOTE / MERGED"
    cmd = nvim -n -c "DiffviewOpen" "$MERGE" -c "DiffviewToggleFiles"

[delta]
    features     = catppuccin-mocha
    navigate     = true       # use n and N to move between diff sections
    dark         = true
    side-by-side = true
    line-numbers = true

[interactive]
    diffFilter = delta --color-only


# ---------------------------------------------------------------
# --- Visuals & Logging
[blame]
    coloring = highlightRecent
    date     = relative

[log]
    abbrevCommit = true       # short commits
    graphColors  = blue,yellow,cyan,magenta,brightgreen,brightred

[color]
    ui          = true
    branch      = auto
    diff        = auto
    interactive = auto
    status      = auto

[color "diff"]
    meta       = black bold
    frag       = magenta
    context    = white
    whitespace = yellow reverse
    old        = brightred

[color "blame"]
    highlightRecent = black bold,1 year ago,white,1 month ago,default,7 days ago,blue

[color "branch"]
    current  = magenta
    local    = default
    remote   = yellow
    upstream = green
    plain    = blue


# ---------------------------------------------------------------
# --- Utilities & Help
[advice]
    statusHints        = false # Remove usage hints
    addEmptyPathspec   = false
    pushNonFastForward = false

[help]
    autocorrect = 1           # Guess what you really meant


# ---------------------------------------------------------------
# --- Shortcuts & Credentials
[url "https://github.com/"]
    insteadOf = gh:

[url "https://gitlab.com/"]
    insteadOf = gl:

[credential "https://github.com"]
    helper = 
    helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper = 
    helper = !/usr/bin/gh auth git-credential
