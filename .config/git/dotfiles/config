# vim:ft=gitconfig
[core]
	repositoryformatversion = 0
	filemode = true
    bare = true
    excludesFile = ~/.config/git/dotfiles/ignore
	logallrefupdates = true

[remote "origin"]
	url = https://github.com/rokumir/.dotfiles.git
	fetch = +refs/heads/*:refs/remotes/origin/*

[branch "main"]
	remote = origin
	merge = refs/heads/main

